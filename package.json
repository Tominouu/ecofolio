{
  "name": "ecofolio",
  "version": "0.1.0",
  "description": "Portfolio studio for students and creatives — static, fast, eco-friendly",
  "type": "module",
  "bin": {
    "ecofolio": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "themes"
  ],
  "scripts": {
    "dev": "tsx watch src/cli/index.ts dev",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@sinclair/typebox": "^0.34.0",
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "ejs": "^3.1.0",
    "fastify": "^5.0.0",
    "htmlnano": "^2.1.0",
    "lightningcss": "^1.28.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.33.0",
    "simple-git": "^3.27.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
